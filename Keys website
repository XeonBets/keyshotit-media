  <script>
    // Load pricing, gallery, about, and contact from data.json
    (async function loadSiteData() {
      try {
        const res = await fetch('./data.json?' + Date.now());
        if (!res.ok) throw new Error('Failed to load data.json');
        const data = await res.json();

        // Pricing
        if (data.pricing) {
          const cards = document.querySelectorAll('.pricing-card');
          data.pricing.forEach((pkg, i) => {
            if (!cards[i]) return;
            const card = cards[i];
            if (pkg.price) {
              card.querySelector('.pricing-price').innerHTML =
                `<span class="currency">$</span>${pkg.price}`;
            }
            if (pkg.description) card.querySelector('.pricing-desc').textContent = pkg.description;
            const features = (pkg.features || []).filter(f => f.trim());
            if (features.length) {
              card.querySelector('.pricing-features').innerHTML =
                features.map(f => `<li>${f}</li>`).join('');
            }
          });
        }

        // Gallery
        if (data.gallery) {
          const galleryItems = document.querySelectorAll('.gallery-item');
          data.gallery.forEach((item, i) => {
            if (!galleryItems[i] || !item.url) return;
            const placeholder = galleryItems[i].querySelector('.gallery-placeholder');
            if (placeholder) {
              const img = document.createElement('img');
              img.src = item.url;
              img.alt = item.label || 'Portfolio photo';
              img.loading = 'lazy';
              placeholder.replaceWith(img);
            }
          });
        }

        // About section
        if (data.about && data.about.bio) {
          const aboutContent = document.getElementById('aboutContent');
          if (aboutContent) {
            const paragraphs = data.about.bio.split('\n\n');
            aboutContent.innerHTML = paragraphs
              .map(p => `<p>${p}</p>`)
              .join('');
          }
        }

        // Contact info
        if (data.contact) {
          const contactInfo = document.getElementById('contactInfo');
          if (contactInfo) {
            let html = '';
            
            if (data.contact.phone) {
              html += `
                <div class="contact-item">
                  <div class="contact-icon">📞</div>
                  <div>
                    <p class="contact-item-label">Phone</p>
                    <p class="contact-item-value"><a href="tel:${data.contact.phone.replace(/\D/g, '')}">${data.contact.phone}</a></p>
                  </div>
                </div>
              `;
            }
            
            if (data.contact.email) {
              html += `
                <div class="contact-item">
                  <div class="contact-icon">✉️</div>
                  <div>
                    <p class="contact-item-label">Email</p>
                    <p class="contact-item-value"><a href="mailto:${data.contact.email}">${data.contact.email}</a></p>
                  </div>
                </div>
              `;
            }
            
            if (data.contact.location) {
              html += `
                <div class="contact-item">
                  <div class="contact-icon">📍</div>
                  <div>
                    <p class="contact-item-label">Location</p>
                    <p class="contact-item-value">${data.contact.location}</p>
                  </div>
                </div>
              `;
            }
            
            if (data.contact.social && data.contact.social.length) {
              html += `
                <div>
                  <p class="contact-item-label" style="margin-bottom: 12px;">Follow Along</p>
                  <div class="social-row">
              `;
              
              data.contact.social.forEach(social => {
                const svgIcon = getSocialIcon(social.icon);
                html += `
                  <a href="${social.url}" target="_blank" rel="noopener noreferrer" class="social-btn" aria-label="${social.name}">
                    ${svgIcon}
                    ${social.name}
                  </a>
                `;
              });
              
              html += `
                  </div>
                </div>
              `;
            }
            
            contactInfo.innerHTML = html;
          }
        }
      } catch(e) {
        console.warn('Could not load data.json:', e.message);
      }
    })();

    function getSocialIcon(name) {
      const icons = {
        instagram: '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0m0 2.16c2.71 0 3.028.01 4.093.059 1.071.049 1.658.228 2.05.381a3.477 3.477 0 011.257.817c.39.39.641.775.817 1.257.153.392.332.979.381 2.05.049 1.065.059 1.383.059 4.093s-.01 3.028-.059 4.093c-.049 1.071-.228 1.658-.381 2.05a3.477 3.477 0 01-.817 1.257c-.39.39-.775.641-1.257.817-.392.153-.979.332-2.05.381-1.065.049-1.383.059-4.093.059s-3.028-.01-4.093-.059c-1.071-.049-1.658-.228-2.05-.381a3.477 3.477 0 01-1.257-.817c-.39-.39-.641-.775-.817-1.257-.153-.392-.332-.979-.381-2.05-.049-1.065-.059-1.383-.059-4.093s.01-3.028.059-4.093c.049-1.071.228-1.658.381-2.05a3.477 3.477 0 01.817-1.257c.39-.39.775-.641 1.257-.817.392-.153.979-.332 2.05-.381 1.065-.049 1.383-.059 4.093-.059z"/></svg>',
        facebook: '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>'
      };
      return icons[name] || '';
    }

    // Nav shrink on scroll
    window.addEventListener('scroll', () => {
      const nav = document.querySelector('nav');
      nav.style.padding = window.scrollY > 60 ? '14px 60px' : '20px 60px';
    });

    // Fade-in on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.style.opacity = '1';
          e.target.style.transform = 'translateY(0)';
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.service-card, .pricing-card, .gallery-item, .contact-item').forEach(el => {
      el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      observer.observe(el);
    });

    // Form submit handler with validation
    const contactForm = document.getElementById('contactForm');
    contactForm.addEventListener('submit', handleSubmit);

    function handleSubmit(e) {
      e.preventDefault();
      
      const nameInput = document.getElementById('nameInput');
      const emailInput = document.getElementById('emailInput');
      const btn = e.target.querySelector('.form-submit');
      
      // Basic validation
      if (!nameInput.value.trim()) {
        showError(nameInput, 'Name is required');
        return;
      }
      if (!emailInput.value.trim() || !isValidEmail(emailInput.value)) {
        showError(emailInput, 'Valid email is required');
        return;
      }
      
      // Clear errors
      document.querySelectorAll('.form-error').forEach(err => err.remove());
      
      // Show success state
      btn.classList.add('success');
      btn.textContent = 'Message Sent ✓';
      
      // Reset form after delay
      setTimeout(() => {
        btn.classList.remove('success');
        btn.textContent = 'Send Message';
        contactForm.reset();
      }, 3000);
    }

    function showError(input, message) {
      const existing = input.nextElementSibling;
      if (existing && existing.classList.contains('form-error')) {
        existing.remove();
      }
      const error = document.createElement('div');
      error.className = 'form-error';
      error.textContent = message;
      input.after(error);
    }

    function isValidEmail(email) {
      const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      return re.test(email);
    }
  </script>
