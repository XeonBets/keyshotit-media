  <script>
    // Load pricing and gallery from data.json
    (async function loadSiteData() {
      try {
        const res = await fetch('./data.json?' + Date.now());
        if (!res.ok) return;
        const data = await res.json();
        const cards = document.querySelectorAll('.pricing-card');

        // Pricing
        (data.pricing || []).forEach((pkg, i) => {
          if (!cards[i]) return;
          const card = cards[i];
          if (pkg.price) {
            card.querySelector('.pricing-price').innerHTML =
              `<span class="currency">$</span>${pkg.price}`;
          }
          if (pkg.description) card.querySelector('.pricing-desc').textContent = pkg.description;
          const features = (pkg.features || []).filter(f => f.trim());
          if (features.length) {
            card.querySelector('.pricing-features').innerHTML =
              features.map(f => `<li>${f}</li>`).join('');
          }
        });

        // Gallery
        const galleryItems = document.querySelectorAll('.gallery-item');
        (data.gallery || []).forEach((item, i) => {
          if (!galleryItems[i] || !item.url) return;
          const placeholder = galleryItems[i].querySelector('.gallery-placeholder');
          if (placeholder) {
            const img = document.createElement('img');
            img.src = item.url;
            img.alt = item.label || 'Portfolio photo';
            placeholder.replaceWith(img);
          }
        });
      } catch(e) {}
    })();

    // Nav shrink on scroll
    window.addEventListener('scroll', () => {
      document.querySelector('nav').style.padding =
        window.scrollY > 60 ? '14px 60px' : '20px 60px';
    });

    // Fade-in on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.style.opacity = '1';
          e.target.style.transform = 'translateY(0)';
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.service-card, .pricing-card, .gallery-item, .contact-item').forEach(el => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(24px)';
      el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      observer.observe(el);
    });

    // Form submit handler
    function handleSubmit(e) {
      e.preventDefault();
      const btn = e.target.querySelector('.form-submit');
      btn.textContent = 'Message Sent ✓';
      btn.style.background = '#2a7a2a';
      btn.style.color = '#fff';
      setTimeout(() => {
        btn.textContent = 'Send Message';
        btn.style.background = '';
        btn.style.color = '';
        e.target.reset();
      }, 3000);
    }
  </script>
